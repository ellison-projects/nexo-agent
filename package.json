{
  "name": "nexo-agent",
  "type": "module",
  "scripts": {
    "dev": "npx tsx --env-file=.env src/index.ts",
    "start": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop nexo-agent",
    "restart": "pkill -f 'tsx.*src/index.ts' || true && pm2 restart nexo-agent",
    "logs": "pm2 logs nexo-agent",
    "status": "pm2 status",
    "reset-session": "rm -f .session-id && npm run restart"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.59"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "pm2": "^5.3.0"
  }
}